        <section id="agents-tab" class="tab-panel active">
          <div class="agents-layout">
            <section class="agents-card">
              <div class="card-header">
                <h2 id="agent-form-title">Add / Edit Agent</h2>
                <p id="agent-form-subtitle">
                  Create a new row in <code>agents</code> or update an existing one.
                </p>
              </div>

              <form id="agents-form" class="agents-form">
                <input type="hidden" id="editing-agent-id" />

                <div class="form-grid">
                  <div class="field">
                    <label for="agent-email">Email</label>
                    <input type="email" id="agent-email" placeholder="agent@email.com" required />
                  </div>

                  <div class="field">
                    <label for="agent-agent-id">Agent ID</label>
                    <input type="text" id="agent-agent-id" placeholder="Agent ID / NPN / internal ID" required />
                  </div>

                  <div class="field">
                    <label for="agent-first-name">First Name</label>
                    <input type="text" id="agent-first-name" placeholder="First name" />
                  </div>

                  <div class="field">
                    <label for="agent-last-name">Last Name</label>
                    <input type="text" id="agent-last-name" placeholder="Last name" />
                  </div>

                  <div class="field field-full">
                    <label for="agent-full-name">Full Name</label>
                    <input type="text" id="agent-full-name" placeholder="Full name" required />
                  </div>

                  <div class="field">
                    <label for="agent-phone">Phone</label>
                    <input type="text" id="agent-phone" placeholder="Optional" />
                  </div>

                  <div class="field">
                    <label for="agent-level">Level</label>
                    <select id="agent-level">
                      <option value="">No level</option>
                      <option value="agent">Agent</option>
                      <option value="mit">MIT</option>
                      <option value="manager">Manager</option>
                      <option value="mga">MGA</option>
                      <option value="area_manager">Area Manager</option>
                    </select>
                  </div>

                  <div class="field">
                    <label for="agent-recruiter-id">Recruiter</label>
                    <select id="agent-recruiter-id">
                      <option value="">No recruiter</option>
                    </select>
                  </div>

                  <div class="field">
                    <label for="agent-agent-slug">Agent Slug</label>
                    <input type="text" id="agent-agent-slug" placeholder="Optional public slug" />
                  </div>

                  <div class="field checkbox-field">
                    <label class="checkbox-wrap">
                      <input type="checkbox" id="agent-is-active" checked />
                      <span>Is Active</span>
                    </label>
                  </div>

                  <div class="field checkbox-field">
                    <label class="checkbox-wrap">
                      <input type="checkbox" id="agent-is-admin" />
                      <span>Is Admin</span>
                    </label>
                  </div>

                  <div class="field checkbox-field">
                    <label class="checkbox-wrap">
                      <input type="checkbox" id="agent-is-available" />
                      <span>Is Available</span>
                    </label>
                  </div>

                  <div class="field checkbox-field">
                    <label class="checkbox-wrap">
                      <input type="checkbox" id="agent-receiving-leads" checked />
                      <span>Receiving Leads</span>
                    </label>
                  </div>

                  <div class="field checkbox-field">
                    <label class="checkbox-wrap">
                      <input type="checkbox" id="agent-show-on-about" />
                      <span>Show On About Page</span>
                    </label>
                  </div>

                  <div class="field checkbox-field">
                    <label class="checkbox-wrap">
                      <input type="checkbox" id="agent-page-enabled" />
                      <span>Agent Page Enabled</span>
                    </label>
                  </div>

                  <div class="field field-full">
                    <label for="agent-companies">Companies</label>
                    <select id="agent-companies" multiple size="6">
                      <option value="Aetna">Aetna</option>
                      <option value="Aflac">Aflac</option>
                      <option value="American Modern">American Modern</option>
                      <option value="CICA">CICA</option>
                      <option value="Mutual of Omaha">Mutual of Omaha</option>
                      <option value="Progressive">Progressive</option>
                      <option value="Transamerica">Transamerica</option>
                      <option value="Prudent Pet">Prudent Pet</option>
                    </select>
                    <small>Use Ctrl / Cmd to select multiple.</small>
                  </div>

                  <div class="field field-full">
                    <label for="agent-product-types">Product Types</label>
                    <select id="agent-product-types" multiple size="8">
                      <option value="Life">Life</option>
                      <option value="Health">Health</option>
                      <option value="Property">Property</option>
                      <option value="Casualty">Casualty</option>
                      <option value="P&C">P&C</option>
                      <option value="Medicare">Medicare</option>
                      <option value="Annuity">Annuity</option>
                      <option value="Legal">Legal</option>
                      <option value="Realty">Realty</option>
                      <option value="Commercial">Commercial</option>
                      <option value="Pet">Pet</option>
                    </select>
                  </div>

                  <div class="field field-full">
                    <label for="agent-timezone">Timezone</label>
                    <input type="text" id="agent-timezone" placeholder="ex: America/Chicago" />
                  </div>

                  <div class="field field-full">
                    <label for="agent-profile-picture-url">Profile Picture URL</label>
                    <input type="text" id="agent-profile-picture-url" placeholder="Optional" />
                  </div>

                  <div class="field field-full">
                    <label for="agent-bio">Bio</label>
                    <textarea id="agent-bio" rows="5" placeholder="Short bio..."></textarea>
                  </div>
                </div>

                <div class="form-actions">
                  <button type="submit" class="primary-btn" id="save-agent-btn">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save Agent
                  </button>

                  <button type="button" id="reset-agent-form-btn" class="secondary-btn">
                    <i class="fa-solid fa-rotate-left"></i>
                    Reset
                  </button>

                  <button type="button" id="cancel-agent-edit-btn" class="cancel-edit-btn hidden">
                    <i class="fa-solid fa-xmark"></i>
                    Cancel Edit
                  </button>
                </div>

                <p id="agents-form-message" class="form-message"></p>
              </form>
            </section>

            <section class="agents-card">
