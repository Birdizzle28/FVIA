                    </select>
                  </div>

                  <div class="field">
                    <label for="recruit-recruiter-id">Recruiter</label>
                    <select id="recruit-recruiter-id" required>
                      <option value="">Select recruiter</option>
                    </select>
                  </div>

                  <div class="field field-full">
                    <label for="recruit-notes">Notes</label>
                    <textarea id="recruit-notes" rows="7" placeholder="Internal recruit notes..."></textarea>
                  </div>
                </div>

                <div class="form-actions">
                  <button type="submit" class="primary-btn" id="save-recruit-btn">
                    <i class="fa-solid fa-floppy-disk"></i>
                    Save Recruit
                  </button>

                  <button type="button" id="reset-recruit-form-btn" class="secondary-btn">
                    <i class="fa-solid fa-rotate-left"></i>
                    Reset
                  </button>

                  <button type="button" id="cancel-recruit-edit-btn" class="cancel-edit-btn hidden">
                    <i class="fa-solid fa-xmark"></i>
                    Cancel Edit
                  </button>
                </div>

                <p id="recruits-form-message" class="form-message"></p>
              </form>
            </section>

            <section class="agents-card">
